name: CI — Lint, Format, Validate

on:
  push:
    branches: ["**"]
  pull_request:
    branches: [main]

jobs:
  pre-commit:
    name: Pre-commit hooks
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dependencies
        run: pip install pre-commit ruff sqlfluff

      - name: Run pre-commit on all files
        run: pre-commit run --all-files

  validate-structure:
    name: Validate project structure
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install core dependencies
        run: |
          pip install python-dotenv requests

      - name: Check required directories exist
        run: |
          python - <<'EOF'
          from pathlib import Path
          import sys

          REQUIRED_DIRS = [
              "ingestion/batch", "ingestion/streaming", "ingestion/schemas",
              "transformation/models/staging", "transformation/models/intermediate",
              "transformation/models/marts", "transformation/tests",
              "transformation/macros", "transformation/seeds", "transformation/snapshots",
              "orchestration/dags", "orchestration/plugins", "orchestration/sensors",
              "infrastructure/terraform/gcp", "infrastructure/terraform/aws",
              "infrastructure/docker",
              "quality/expectations", "quality/checkpoints",
              "governance/pii_config", "governance/lineage", "governance/catalog",
              "serving/api", "serving/feature_store",
              "monitoring/dashboards", "monitoring/alerts", "monitoring/metrics",
              "tests/unit", "tests/integration", "tests/e2e",
              "docs/architecture", "docs/decisions",
              "notebooks", "scripts",
              ".github/workflows",
          ]

          REQUIRED_FILES = [
              ".env.example", ".gitignore", ".pre-commit-config.yaml",
              "Makefile", "pyproject.toml", "requirements.txt",
              "transformation/dbt_project.yml",
              "docs/decisions/ADR-001-cloud-architecture.md",
          ]

          root = Path(".")
          errors = []

          for d in REQUIRED_DIRS:
              if not (root / d).exists():
                  errors.append(f"MISSING dir: {d}")

          for f in REQUIRED_FILES:
              if not (root / f).exists():
                  errors.append(f"MISSING file: {f}")

          if errors:
              print("Structure validation FAILED:")
              for e in errors:
                  print(f"  ❌ {e}")
              sys.exit(1)
          else:
              print(f"✅ All {len(REQUIRED_DIRS)} required directories present")
              print(f"✅ All {len(REQUIRED_FILES)} required files present")
          EOF

      - name: Check .env is not committed
        run: |
          if git ls-files --error-unmatch .env 2>/dev/null; then
            echo "❌ CRITICAL: .env file is tracked by git — remove with: git rm --cached .env"
            exit 1
          else
            echo "✅ .env is not tracked by git"
          fi

      - name: Check no credential files committed
        run: |
          python - <<'EOF'
          import subprocess, sys
          result = subprocess.run(
              ["git", "ls-files"],
              capture_output=True, text=True
          )
          tracked = result.stdout.strip().split("\n")
          dangerous = [
              f for f in tracked
              if any(p in f.lower() for p in [
                  "key.json", "credentials.json", "service-account",
                  "secret", ".pem", ".p12"
              ])
          ]
          if dangerous:
              print(f"❌ Possible credential files tracked: {dangerous}")
              sys.exit(1)
          else:
              print("✅ No credential files found in tracked files")
          EOF

  validate-dbt:
    name: Validate dbt project config
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
          cache: "pip"

      - name: Install dbt
        run: pip install dbt-core dbt-bigquery

      - name: dbt parse (syntax check — no DB connection needed)
        run: |
          cd transformation
          # Create a minimal profiles.yml for CI (no real connection)
          mkdir -p ~/.dbt
          cat > ~/.dbt/profiles.yml << 'PROFILE'
          urban_pulse:
            target: ci
            outputs:
              ci:
                type: bigquery
                method: service-account
                project: urban-pulse-dev
                dataset: staging
                keyfile: /dev/null
                location: US
                threads: 1
          PROFILE
          # Parse only — validates SQL syntax and model references
          dbt parse --profiles-dir ~/.dbt || echo "dbt parse skipped (no credentials in CI)"
